# Copy this file to .env and fill in real values before running.

# PostgreSQL connection
DATABASE_URL=postgres://username:password@localhost:5432/unplug

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Port the API server listens on
PORT=4000

# Comma-separated list of origins allowed to call this API (your frontend URLs)
CORS_ORIGINS=http://localhost:3000,https://www.unplugnews.com

# Payment gateway merchant credentials — required to verify that webhook
# calls to /payments/payfast/webhook and /payments/ozow/webhook are
# genuinely from PayFast/Ozow and not forged. Leave unset for local
# development (verification is skipped with a console warning) but set
# both before accepting real payments.
PAYFAST_PASSPHRASE=
OZOW_PRIVATE_KEY=

# Object storage for uploaded images (Supabase Storage). When all three are
# set, POST /uploads stores files in a PUBLIC Supabase bucket and returns
# their permanent public URL, instead of the server's local disk (which is
# wiped on every redeploy on free/ephemeral hosts). Create a PUBLIC bucket
# in Supabase → Storage, then set:
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=uploads

# Email (signup verification codes, password resets). Leave everything unset
# for local development — messages are logged to the console instead of sent.
#
# PREFERRED: an HTTPS API. Set ONE of these. They send over port 443, which
# hosts never block — unlike SMTP ports, which Render blocks outbound (a
# blocked SMTP port shows up as a bare "Connection timeout" that looks
# identical to a wrong hostname, so it is worth avoiding entirely).
RESEND_API_KEY=
BREVO_API_KEY=

# FALLBACK: SMTP, for local dev or a host that allows outbound mail ports.
# For this project's cPanel account the working values are
# cp73.domains.co.za:465 — NOT mail.unplugnews.com, whose TLS certificate
# only covers *.domains.co.za. SMTP_SECURE is derived from the port
# (465 = true) unless set explicitly.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# The sending address, used by whichever transport is active.
SMTP_FROM=Unplug Magazine <no-reply@unplugnews.com>
